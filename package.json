{
  "name": "nolanx",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source NolanX monorepo: web app, API server, and Python agent runtime.",
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "dev": "bash scripts/dev.sh",
    "check": "bash scripts/check.sh",
    "dev:web": "pnpm --dir apps/web dev",
    "dev:api": "pnpm --dir apps/api dev",
    "dev:agent": "cd apps/agent && .venv/bin/python main.py --host 127.0.0.1 --port 52178"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9",
    "python": ">=3.10"
  },
  "packageManager": "pnpm@9.15.4"
}
